generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id          Int        @id @default(autoincrement())
  title       String
  description String
  period      String
  region      String
  language    String
  createdAt   DateTime   @default(now())

  documents   Document[]
}

model Document {
  id          Int       @id @default(autoincrement())
  name        String
  fileName    String
  fileType    String
  fileSize    Int
  filePath    String
  status      String    @default("uploaded")
  createdAt   DateTime  @default(now())

  projectId   Int
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}